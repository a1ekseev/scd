{
  "name": "sfc",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.14.0"
  },
  "bin": {
    "sfc": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p ./tsconfig.build.json",
    "typecheck": "tsc -p ./tsconfig.json --noEmit",
    "start": "node ./dist/cli.js",
    "serve": "node ./dist/cli.js serve",
    "refresh": "node ./dist/cli.js refresh",
    "test": "node --test ./test/**/*.test.ts"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "cron-parser": "^5.4.0",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.1",
    "yaml": "^2.8.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.2"
  }
}
